---
import "@fontsource/instrument-serif/400.css";
import "@fontsource/instrument-serif/400-italic.css";
import "@fontsource/ibm-plex-sans/400.css";
import "@fontsource/ibm-plex-sans/500.css";
import "@fontsource/ibm-plex-mono/400.css";
import "leaflet/dist/leaflet.css";
import "../styles/global.css";
import { Image } from "astro:assets";
import logoRed from "../assets/logos/ZFT_logo-02.svg";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Žagarė for today",
  description = "Interaktyvus Žagarės žemėlapis: lankytinos vietos, kavinės, parduotuvės, istorija ir gamta. Miestelio gidas, kurį leidžia vietos bendruomenė.",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL("/og.png", Astro.site).toString();
const siteOrigin = Astro.site!.toString().replace(/\/$/, "");

const siteSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteOrigin}/#website`,
      url: `${siteOrigin}/`,
      name: "Žagarė for today",
      description:
        "Žagarės miestelio gidas - lankytinos vietos, istorija, bendruomenė.",
      inLanguage: "lt-LT",
      publisher: { "@id": `${siteOrigin}/#organization` },
    },
    {
      "@type": "NGO",
      "@id": `${siteOrigin}/#organization`,
      name: 'Asociacija "Žagarės laisvamaniai"',
      legalName: 'Asociacija "Žagarės laisvamaniai"',
      taxID: "307234973",
      url: `${siteOrigin}/`,
      email: "labas@zagare.today",
      sameAs: ["https://www.facebook.com/zagareslaisvamaniai"],
      address: {
        "@type": "PostalAddress",
        streetAddress: "Raktuvės g. 11-1",
        addressLocality: "Žagarė",
        addressRegion: "Joniškio r.",
        postalCode: "LT-84316",
        addressCountry: "LT",
      },
      areaServed: { "@id": `${siteOrigin}/#place` },
    },
    {
      "@type": "Place",
      "@id": `${siteOrigin}/#place`,
      name: "Žagarė",
      description:
        "Miestelis Lietuvos šiaurėje, Joniškio rajone, prie Latvijos sienos. Žagarės regioninis parkas.",
      geo: {
        "@type": "GeoCoordinates",
        latitude: 56.359326,
        longitude: 23.255060,
      },
      containedInPlace: {
        "@type": "AdministrativeArea",
        name: "Joniškio rajono savivaldybė",
        containedInPlace: {
          "@type": "Country",
          name: "Lietuva",
          identifier: "LT",
        },
      },
    },
  ],
};
---

<!doctype html>
<html lang="lt">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://a.basemaps.cartocdn.com" crossorigin />
    <link rel="dns-prefetch" href="https://a.basemaps.cartocdn.com" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#eaddca" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Žagarė for today" />
    <meta property="og:locale" content="lt_LT" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />
    <title>{title}</title>
    <script
      type="application/ld+json"
      set:html={JSON.stringify(siteSchema).replace(/</g, "\\u003c")}
      is:inline
    />
  </head>
  <body class="min-h-dvh bg-paper text-ink antialiased font-sans">
    <header class="border-b border-ink/15">
      <div class="mx-auto flex h-14 items-center justify-between px-5 md:px-8">
        <a
          href="/"
          class="flex items-center gap-2.5"
          aria-label="Žagarė for today - pradžia"
        >
          <Image
            src={logoRed}
            alt=""
            class="h-7 w-auto"
            loading="eager"
            decoding="sync"
          />
          <span class="font-display text-[22px] leading-none text-ink">
            Žagarė <span class="italic text-brand-600">for today</span>
          </span>
        </a>
        <div class="flex items-center gap-5 md:gap-8">
          <nav aria-label="Pagrindinė navigacija">
            <a
              href="/kontaktai"
              class="meta hover:text-brand-600 transition-colors"
              aria-current={Astro.url.pathname === "/kontaktai"
                ? "page"
                : undefined}
            >
              Kontaktai
            </a>
          </nav>
          <p class="meta text-right leading-[1.4] whitespace-nowrap hidden sm:block">
            56°21.55958′N<br />
            23°15.30359′E
          </p>
        </div>
      </div>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
