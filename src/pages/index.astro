---
import Layout from "../layouts/Layout.astro";
import MapExperience from "../components/Map.tsx";
import {
  CATEGORIES,
  CATEGORY_KEYS,
  POINTS,
  type Category,
} from "../data/points";

const siteOrigin = Astro.site!.toString().replace(/\/$/, "");
const placeId = `${siteOrigin}/#place`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Žagarės žemėlapio taškai",
  itemListElement: POINTS.map((p, i) => {
    const sameAs = [p.wikiUrl, p.instagramUrl].filter(Boolean);
    return {
      "@type": "ListItem",
      position: i + 1,
      item: {
        "@type": "TouristAttraction",
        name: p.name,
        description: p.description,
        containedInPlace: { "@id": placeId },
        geo: {
          "@type": "GeoCoordinates",
          latitude: p.lat,
          longitude: p.lng,
        },
        ...(p.images?.[0] && {
          image: `${siteOrigin}${p.images[0].src}`,
        }),
        ...(sameAs.length > 0 && { sameAs }),
      },
    };
  }),
};

const pointsByCategory = CATEGORY_KEYS.map((c: Category) => ({
  key: c,
  label: CATEGORIES[c].label,
  items: POINTS.filter((p) => p.category === c),
})).filter((g) => g.items.length > 0);
---

<Layout title="Žagarė for today - miestelio žemėlapis">
  <script
    type="application/ld+json"
    set:html={JSON.stringify(structuredData).replace(/</g, "\\u003c")}
    is:inline
  />
  <section class="relative px-5 md:px-8 pt-10 md:pt-16 pb-10 md:pb-16">
    <h1
      class="font-display not-italic tracking-tight leading-[0.86] text-ink"
    >
      <span class="block text-[clamp(3.6rem,15vw,12rem)]">Žagarė</span>
      <span
        class="block italic text-[clamp(3.2rem,13vw,10.5rem)] pl-[0.5em] text-ink-soft"
        >for</span
      >
      <span
        class="block italic text-[clamp(3.6rem,15vw,12rem)] pl-[1.2em] text-brand-600"
        >today</span
      >
      <span class="sr-only">
        : interaktyvus Žagarės miestelio žemėlapis, lankytinos vietos ir
        gidas
      </span>
    </h1>

    <h2 class="sr-only">Apie Žagarę</h2>
    <div class="mt-10 md:mt-16 grid md:grid-cols-12 gap-6 md:gap-10">
      <div
        class="md:col-span-5 md:col-start-8 border-l-2 border-brand-600 pl-4 md:pl-5"
      >
        <p class="font-sans text-[15px] md:text-[17px] leading-[1.55] text-ink">
          Miestelis Lietuvos šiaurėje, prie pat Latvijos sienos - augęs iš
          dviejų gyvenviečių priešinguose Švėtės krantuose. Dvi aikštės, dvi
          istorijos, vienas miestas. Šiandien Žagarę toliau kuria pati
          bendruomenė - talkomis, atvirais kiemais, vyšnių sodais, naujomis
          idėjomis ant senų pamatų. Šis leidinys - <em
            class="font-display italic text-[19px]">gyvas</em
          >: renkame vietas, klausomės žmonių, užrašome tai, kas dar tik
          gimsta.
        </p>
      </div>
    </div>
  </section>

  <div class="mx-5 md:mx-8 h-px bg-ink/15"></div>

  <h2 class="sr-only">Žagarės žemėlapis ir lankytinos vietos</h2>
  <MapExperience client:only="react">
    <div
      slot="fallback"
      class="mx-5 md:mx-8 my-8 md:my-12 h-[60dvh] md:h-[72dvh] border border-ink/30 flex items-center justify-center"
    >
      <p class="meta">Kraunamas žemėlapis…</p>
    </div>
  </MapExperience>

  <section class="sr-only" aria-label="Visos lankytinos vietos">
    <h2>Žagarės lankytinos vietos pagal kategoriją</h2>
    {
      pointsByCategory.map((group) => (
        <section>
          <h3>{group.label}</h3>
          <ul>
            {group.items.map((p) => (
              <li>
                <strong>{p.name}</strong>. {p.description}
                {" "}
                <span>
                  Koordinatės: {p.lat.toFixed(6)}, {p.lng.toFixed(6)}.
                </span>
                {p.wikiUrl && (
                  <span>
                    {" "}
                    <a href={p.wikiUrl} rel="noopener noreferrer">
                      Wikipedia
                    </a>
                    .
                  </span>
                )}
                {p.instagramUrl && (
                  <span>
                    {" "}
                    <a href={p.instagramUrl} rel="noopener noreferrer">
                      Instagram
                    </a>
                    .
                  </span>
                )}
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </section>

  <div class="mx-5 md:mx-8 h-px bg-ink/15"></div>

  <footer
    class="mx-5 md:mx-8 py-6 meta flex flex-col md:flex-row justify-between gap-2"
  >
    <span>Žagarė, Joniškio r., Lietuva</span>
    <a
      href="/kontaktai"
      class="hover:text-brand-600 transition-colors"
      >Asociacija „Žagarės laisvamaniai“</a
    >
    <span>© {new Date().getFullYear()} Žagarė for today</span>
  </footer>
</Layout>
