---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import FestivalMap from "../components/FestivalMap.tsx";
import { FESTIVAL_POINTS } from "../data/festival";
import festivalHero from "../assets/festival/vysniu-festivalis-hero.webp";

const siteOrigin = Astro.site!.toString().replace(/\/$/, "");
const placeId = `${siteOrigin}/#place`;
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const FEST_START = "2026-07-16";
const FEST_END = "2026-07-19";
const heroImageAbs = `${siteOrigin}${festivalHero.src}`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Vyšnių festivalio žemėlapis",
  itemListElement: FESTIVAL_POINTS.map((p, i) => {
    const sameAs = [p.wikiUrl, p.instagramUrl, p.facebookUrl].filter(Boolean);
    return {
      "@type": "ListItem",
      position: i + 1,
      item: {
        "@type": "Place",
        name: p.name,
        description: p.description,
        containedInPlace: { "@id": placeId },
        geo: {
          "@type": "GeoCoordinates",
          latitude: p.lat,
          longitude: p.lng,
        },
        ...(p.images?.[0] && {
          image: `${siteOrigin}${p.images[0].src}`,
        }),
        ...(sameAs.length > 0 && { sameAs }),
      },
    };
  }),
};

const festivalLocation = {
  "@type": "Place",
  name: "Žagarė",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Žagarė",
    addressRegion: "Joniškio r.",
    postalCode: "LT-84316",
    addressCountry: "LT",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 56.359377,
    longitude: 23.25505,
  },
};

const dayToISODate = (day: string): string | null => {
  const m = day.match(/liepos\s+(\d{1,2})\s*d\./i);
  return m ? `2026-07-${m[1].padStart(2, "0")}` : null;
};

// One Event per (point, dated schedule day). Undated blocks ("Darbo laikas")
// and point-only markers (parking) are skipped so no invalid dates leak out.
const subEvents = FESTIVAL_POINTS.flatMap((p) =>
  (p.schedule ?? []).flatMap((d) => {
    const startDate = dayToISODate(d.day);
    if (!startDate) return [];
    return [
      {
        "@type": "Event",
        name: `${p.name} · ${d.day}`,
        startDate,
        eventStatus: "https://schema.org/EventScheduled",
        eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
        location: {
          "@type": "Place",
          name: p.name,
          geo: {
            "@type": "GeoCoordinates",
            latitude: p.lat,
            longitude: p.lng,
          },
        },
        description: d.items
          .map((it) => (it.time ? `${it.time} ${it.text}` : it.text))
          .join("; "),
      },
    ];
  }),
);

const festivalGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Festival",
      "@id": `${pageUrl}#festival`,
      name: "Žagarės vyšnių festivalis 2026",
      startDate: FEST_START,
      endDate: FEST_END,
      eventStatus: "https://schema.org/EventScheduled",
      eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
      location: festivalLocation,
      image: [heroImageAbs],
      url: pageUrl,
      description:
        "Žagarės vyšnių festivalis 2026 - koncertai, scenos, parodos, amatų mugė ir veiklos visame Žagarės miestelyje liepos 16-19 d.",
      organizer: { "@id": `${siteOrigin}/#organization` },
      sameAs: ["https://vysniufestivalis.lt/"],
      ...(subEvents.length > 0 && { subEvent: subEvents }),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Pradžia",
          item: `${siteOrigin}/`,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Vyšnių festivalis",
          item: pageUrl,
        },
      ],
    },
  ],
};
---

<Layout
  title="Žagarės vyšnių festivalis 2026 - programa ir žemėlapis"
  description="Žagarės vyšnių festivalis 2026, liepos 16-19 d. Interaktyvus žemėlapis su visomis renginio vietomis: scenos, koncertai, parodos, amatų mugė ir veiklos Žagarėje."
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(festivalGraph).replace(/</g, "\\u003c")}
    is:inline
  />
  {
    FESTIVAL_POINTS.length > 0 && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(structuredData).replace(/</g, "\\u003c")}
        is:inline
      />
    )
  }
  <section class="relative px-5 md:px-8 pt-10 md:pt-16 pb-10 md:pb-16">
    <Image
      src={festivalHero}
      alt="Žagarės vyšnių festivalis - folkloro stiliaus gėlių iliustracija su užrašu „2026 07 16-19. Viva Žagarė!“"
      widths={[640, 960, 1280, 1600]}
      sizes="(min-width: 768px) calc(100vw - 4rem), calc(100vw - 2.5rem)"
      class="w-full h-auto border border-ink/20 mb-8 md:mb-12"
      loading="eager"
    />
    <h1
      class="font-display not-italic tracking-tight leading-[0.86] text-ink"
    >
      <span class="block text-[clamp(2rem,6vw,4.2rem)]"
        >Vyšnių festivalio <span class="italic text-brand-600">žemėlapis</span></span
      >
    </h1>
    <p
      class="mt-6 md:mt-8 max-w-2xl font-sans text-ink-soft leading-relaxed text-[15px] md:text-base"
    >
      Žagarės vyšnių festivalis 2026 vyksta liepos 16-19 d. Žemėlapyje - visos
      renginio vietos: scenos, koncertai, parodos, amatų mugė ir veiklos
      visame Žagarės miestelyje.
    </p>
    <p class="mt-4 meta">
      Daugiau informacijos:{" "}
      <a
        href="https://vysniufestivalis.lt/"
        target="_blank"
        rel="noopener"
        class="text-brand-600 underline underline-offset-2 hover:no-underline"
      >
        vysniufestivalis.lt
      </a>
    </p>
  </section>

  <div class="mx-5 md:mx-8 h-px bg-ink/15"></div>

  <h2 class="sr-only">Vyšnių festivalio žemėlapis ir vietos</h2>
  <FestivalMap client:only="react">
    <div
      slot="fallback"
      class="mx-5 md:mx-8 my-8 md:my-12 h-[60dvh] md:h-[72dvh] border border-ink/30 flex items-center justify-center"
    >
      <p class="meta">Kraunamas žemėlapis...</p>
    </div>
  </FestivalMap>

  {
    FESTIVAL_POINTS.length > 0 && (
      <section class="sr-only" aria-label="Visos festivalio vietos">
        <h2>Vyšnių festivalio vietos</h2>
        <ul>
          {FESTIVAL_POINTS.map((p) => (
            <li>
              <strong>{p.name}</strong>. {p.description}{" "}
              <span>
                Koordinatės: {p.lat.toFixed(6)}, {p.lng.toFixed(6)}.
              </span>
              {p.schedule?.map((d) => (
                <span>
                  {" "}
                  {d.day}:{" "}
                  {d.items
                    .map((it) => (it.time ? `${it.time} ${it.text}` : it.text))
                    .join("; ")}
                  .
                </span>
              ))}
            </li>
          ))}
        </ul>
      </section>
    )
  }
</Layout>
